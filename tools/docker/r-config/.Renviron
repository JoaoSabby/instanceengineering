TZ=America/Sao_Paulo
CRAN=https://cloud.r-project.org
R_REPOS=https://cloud.r-project.org

TMPDIR=/workspace/instenginer/tmp
R_USER_CACHE_DIR=/workspace/instenginer/cache
R_LIBS_USER=/opt/R/4.5.3/lib/R/library

MC_CORES=2
OMP_NUM_THREADS=2
OMP_PROC_BIND=close
OMP_PLACES=cores
OMP_DYNAMIC=FALSE
OMP_WAIT_POLICY=PASSIVE

RCPP_PARALLEL_NUM_THREADS=1
R_FUTURE_PLAN=multisession
R_FUTURE_GLOBALS_MAXSIZE=8GB
R_FUTURE_SUPPORTSMULTICORE_UNSTABLE=quiet
R_FUTURE_FORK_ENABLE=FALSE

OPENBLAS_NUM_THREADS=1
BLIS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
MKL_NUM_THREADS=1
MKL_DYNAMIC=FALSE

R_COMPILE_PKGS=1
R_ENABLE_JIT=3
